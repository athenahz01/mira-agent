    "test:rls": "node --env-file-if-exists=.env.local --experimental-strip-types scripts/test-rls.ts",
    "test:onboarding": "node --env-file-if-exists=.env.local --experimental-strip-types scripts/test-onboarding.ts",
    "test:voice-guide-shape": "node --env-file-if-exists=.env.local --experimental-strip-types scripts/test-voice-guide-shape.ts",
    "test:media-kit": "node --env-file-if-exists=.env.local --experimental-strip-types scripts/test-media-kit.ts",
    "test:gmail-encryption": "node --env-file-if-exists=.env.local --experimental-strip-types scripts/test-gmail-encryption.ts",
    "test:pdf-render": "node --env-file-if-exists=.env.local --experimental-strip-types scripts/test-pdf-render.ts",
    "test:brand-identity": "node --env-file-if-exists=.env.local --experimental-strip-types scripts/test-brand-identity.ts",
