NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic API key used for voice and media kit generation.
ANTHROPIC_API_KEY=

# Optional override for the writing model. Defaults to claude-opus-4-7.
ANTHROPIC_MODEL=

# Optional override for media kit assembly. Defaults to claude-sonnet-4-5.
ANTHROPIC_SONNET_MODEL=

# Hunter.io contact enrichment. Free tier is enough for development smoke tests.
HUNTER_API_KEY=
HUNTER_RATE_LIMIT_PER_MINUTE=10

# Google OAuth client for Gmail connect.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# 32-byte hex key for AES-256-GCM refresh token encryption.
GMAIL_TOKEN_ENCRYPTION_KEY=

# Supabase CLI access token used for Docker-free remote type generation.
SUPABASE_ACCESS_TOKEN=

# Remote database password used by Supabase CLI for db push and type generation.
SUPABASE_DB_PASSWORD=

# Supabase project ref, e.g. the subdomain in https://<ref>.supabase.co.
SUPABASE_PROJECT_REF=

# Optional IPv4 pooler host from Supabase Database settings.
SUPABASE_DB_POOLER_HOST=
