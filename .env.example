NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key used for Phase 1b voice guide generation.
ANTHROPIC_API_KEY=

# Optional override for the writing model. Defaults to claude-opus-4-7.
ANTHROPIC_MODEL=

# Supabase CLI access token used for Docker-free remote type generation.
SUPABASE_ACCESS_TOKEN=

# Remote database password used by Supabase CLI for db push and type generation.
SUPABASE_DB_PASSWORD=

# Supabase project ref, e.g. the subdomain in https://<ref>.supabase.co.
SUPABASE_PROJECT_REF=

# Optional IPv4 pooler host from Supabase Database settings.
SUPABASE_DB_POOLER_HOST=
